# Copy these values into the deployment .env. Never commit the completed file.
# Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://planner.domoforge.com/api/auth/google/callback

# Google reCAPTCHA Admin Console. Use a score-based reCAPTCHA v3 key.
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5
