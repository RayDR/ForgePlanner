generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  pending
  active
  suspended
  disabled
  deleted
}

enum PlanAccessLevel {
  editor
  viewer
}

enum PlanAccessStatus {
  pending
  accepted
  declined
  revoked
}

enum PlanVersionSource {
  USER
  IMPORT
  MIGRATION
  SYSTEM
  TRASH_DELETE
  TRASH_RESTORE
  VERSION_RESTORE
  AI_GENERATION
  AI_REFINEMENT
  AI_PATCH
}

model User {
  id                      String                    @id @default(uuid()) @db.Uuid
  email                   String                    @unique @db.VarChar(320)
  passwordHash            String?                   @map("password_hash")
  status                  UserStatus                @default(active)
  emailVerifiedAt         DateTime?                 @map("email_verified_at")
  termsAcceptedAt         DateTime?                 @map("terms_accepted_at")
  lastLoginAt             DateTime?                 @map("last_login_at")
  createdAt               DateTime                  @default(now()) @map("created_at")
  updatedAt               DateTime                  @updatedAt @map("updated_at")
  deletedAt               DateTime?                 @map("deleted_at")
  profile                 Profile?
  roles                   UserRole[]
  sessions                Session[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  notifications           Notification[]
  notificationPreference  NotificationPreference?
  organizationMemberships OrganizationMember[]
  conversationMemberships ConversationParticipant[]
  sentMessages            Message[]
  ownedPlans              Plan[]                    @relation("PlanOwner")
  deletedPlans            Plan[]                    @relation("PlanDeletedBy")
  planAccess              PlanAccess[]              @relation("PlanAccessUser")
  grantedPlanAccess       PlanAccess[]              @relation("PlanAccessGrantor")
  actorAuditLogs          AuditLog[]                @relation("AuditActor")
  effectiveAuditLogs      AuditLog[]                @relation("AuditEffective")
  actorPlanVersions       PlanVersion[]             @relation("PlanVersionActor")
  effectivePlanVersions   PlanVersion[]             @relation("PlanVersionEffective")
  impersonationsStarted   ImpersonationSession[]    @relation("ImpersonationAdmin")
  impersonationsReceived  ImpersonationSession[]    @relation("ImpersonationTarget")
  externalIdentities      ExternalIdentity[]
}

model ExternalIdentity {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  provider       String   @db.VarChar(40)
  providerUserId String   @map("provider_user_id") @db.VarChar(255)
  providerEmail  String?  @map("provider_email") @db.VarChar(320)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId, provider])
}

model Profile {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @unique @map("user_id") @db.Uuid
  displayName   String   @map("display_name") @db.VarChar(80)
  handle        String   @db.VarChar(40)
  discriminator String   @db.VarChar(8)
  avatarUrl     String?  @map("avatar_url") @db.VarChar(500)
  bio           String?  @db.VarChar(280)
  locale        String   @default("es") @db.VarChar(10)
  timezone      String   @default("UTC") @db.VarChar(80)
  preferences   Json     @default("{}")
  searchable    Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([handle, discriminator])
  @@index([handle])
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  key         String           @unique @db.VarChar(40)
  name        String           @db.VarChar(80)
  description String?          @db.VarChar(240)
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  key         String           @unique @db.VarChar(80)
  description String?          @db.VarChar(240)
  roles       RolePermission[]
}

model UserRole {
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Session {
  id            String                @id @default(uuid()) @db.Uuid
  userId        String                @map("user_id") @db.Uuid
  tokenHash     String                @unique @map("token_hash") @db.Char(64)
  csrfTokenHash String                @map("csrf_token_hash") @db.Char(64)
  expiresAt     DateTime              @map("expires_at")
  lastSeenAt    DateTime              @default(now()) @map("last_seen_at")
  revokedAt     DateTime?             @map("revoked_at")
  ipAddress     String?               @map("ip_address") @db.VarChar(64)
  userAgent     String?               @map("user_agent") @db.VarChar(500)
  createdAt     DateTime              @default(now()) @map("created_at")
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonation ImpersonationSession?

  @@index([userId, expiresAt])
}

model PasswordResetToken {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  tokenHash   String    @unique @map("token_hash") @db.Char(64)
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")
  requestedIp String?   @map("requested_ip") @db.VarChar(64)
  userAgent   String?   @map("user_agent") @db.VarChar(500)
  createdAt   DateTime  @default(now()) @map("created_at")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model EmailVerificationToken {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  tokenHash   String    @unique @map("token_hash") @db.Char(64)
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")
  requestedIp String?   @map("requested_ip") @db.VarChar(64)
  userAgent   String?   @map("user_agent") @db.VarChar(500)
  createdAt   DateTime  @default(now()) @map("created_at")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model NotificationPreference {
  userId               String  @id @map("user_id") @db.Uuid
  inAppPlanInvitations Boolean @default(true) @map("in_app_plan_invitations")
  inAppPlanUpdates     Boolean @default(true) @map("in_app_plan_updates")
  emailPlanInvitations Boolean @default(false) @map("email_plan_invitations")
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  type      String    @db.VarChar(80)
  data      Json      @default("{}")
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

model Organization {
  id        String               @id @default(uuid()) @db.Uuid
  name      String               @db.VarChar(120)
  slug      String               @unique @db.VarChar(80)
  createdAt DateTime             @default(now()) @map("created_at")
  updatedAt DateTime             @updatedAt @map("updated_at")
  members   OrganizationMember[]
}

model OrganizationMember {
  organizationId String       @map("organization_id") @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  role           String       @default("member") @db.VarChar(20)
  joinedAt       DateTime     @default(now()) @map("joined_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([organizationId, userId])
  @@index([userId])
}

model Conversation {
  id           String                    @id @default(uuid()) @db.Uuid
  createdAt    DateTime                  @default(now()) @map("created_at")
  updatedAt    DateTime                  @updatedAt @map("updated_at")
  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  conversationId String       @map("conversation_id") @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  joinedAt       DateTime     @default(now()) @map("joined_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @map("conversation_id") @db.Uuid
  senderUserId   String       @map("sender_user_id") @db.Uuid
  body           String       @db.VarChar(4000)
  createdAt      DateTime     @default(now()) @map("created_at")
  editedAt       DateTime?    @map("edited_at")
  deletedAt      DateTime?    @map("deleted_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderUserId], references: [id], onDelete: Restrict)

  @@index([conversationId, createdAt])
}

model AuditLog {
  id                     String                @id @default(uuid()) @db.Uuid
  action                 String                @db.VarChar(100)
  actorUserId            String?               @map("actor_user_id") @db.Uuid
  effectiveUserId        String?               @map("effective_user_id") @db.Uuid
  targetType             String?               @map("target_type") @db.VarChar(80)
  targetId               String?               @map("target_id") @db.VarChar(100)
  metadata               Json                  @default("{}")
  ipAddress              String?               @map("ip_address") @db.VarChar(64)
  userAgent              String?               @map("user_agent") @db.VarChar(500)
  impersonationSessionId String?               @map("impersonation_session_id") @db.Uuid
  createdAt              DateTime              @default(now()) @map("created_at")
  actorUser              User?                 @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  effectiveUser          User?                 @relation("AuditEffective", fields: [effectiveUserId], references: [id], onDelete: SetNull)
  impersonationSession   ImpersonationSession? @relation(fields: [impersonationSessionId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
  @@index([actorUserId, createdAt])
}

model ImpersonationSession {
  id           String     @id @default(uuid()) @db.Uuid
  sessionId    String     @unique @map("session_id") @db.Uuid
  adminUserId  String     @map("admin_user_id") @db.Uuid
  targetUserId String     @map("target_user_id") @db.Uuid
  reason       String?    @db.VarChar(500)
  startedAt    DateTime   @default(now()) @map("started_at")
  expiresAt    DateTime   @map("expires_at")
  endedAt      DateTime?  @map("ended_at")
  ipAddress    String?    @map("ip_address") @db.VarChar(64)
  userAgent    String?    @map("user_agent") @db.VarChar(500)
  session      Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  adminUser    User       @relation("ImpersonationAdmin", fields: [adminUserId], references: [id], onDelete: Restrict)
  targetUser   User       @relation("ImpersonationTarget", fields: [targetUserId], references: [id], onDelete: Restrict)
  auditLogs    AuditLog[]
}

model Plan {
  id               String         @id @default(uuid()) @db.Uuid
  ownerUserId      String         @map("owner_user_id") @db.Uuid
  name             String         @db.VarChar(160)
  objective        String?        @db.Text
  startDate        DateTime       @map("start_date") @db.Date
  endDate          DateTime       @map("end_date") @db.Date
  status           String         @default("active") @db.VarChar(30)
  snapshot         Json
  revision         Int            @default(1)
  importKey        String?        @map("import_key") @db.VarChar(120)
  clientMutationId String?        @map("client_mutation_id") @db.Uuid
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  deletedAt        DateTime?      @map("deleted_at")
  purgeAfter       DateTime?      @map("purge_after")
  deletedByUserId  String?        @map("deleted_by_user_id") @db.Uuid
  sharingEnabled   Boolean        @default(true) @map("sharing_enabled")
  owner            User           @relation("PlanOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  deletedBy        User?          @relation("PlanDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)
  access           PlanAccess[]
  shareLink        PlanShareLink?
  versions         PlanVersion[]

  @@unique([ownerUserId, importKey])
  @@unique([ownerUserId, clientMutationId])
  @@unique([id, revision])
  @@index([ownerUserId, deletedAt, updatedAt])
  @@index([purgeAfter, id])
}

model PlanVersion {
  id                    String            @id @default(uuid()) @db.Uuid
  planId                String            @map("plan_id") @db.Uuid
  revision              Int
  schemaVersion         Int               @map("schema_version")
  snapshot              Json
  source                PlanVersionSource
  actorUserId           String?           @map("actor_user_id") @db.Uuid
  effectiveUserId       String?           @map("effective_user_id") @db.Uuid
  parentVersionId       String?           @map("parent_version_id") @db.Uuid
  restoredFromVersionId String?           @map("restored_from_version_id") @db.Uuid
  checksum              String            @db.Char(64)
  snapshotSizeBytes     Int               @map("snapshot_size_bytes")
  createdAt             DateTime          @default(now()) @map("created_at")
  plan                  Plan              @relation(fields: [planId], references: [id], onDelete: Cascade)
  actorUser             User?             @relation("PlanVersionActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  effectiveUser         User?             @relation("PlanVersionEffective", fields: [effectiveUserId], references: [id], onDelete: SetNull)
  parentVersion         PlanVersion?      @relation("PlanVersionParent", fields: [parentVersionId], references: [id], onDelete: SetNull)
  childVersions         PlanVersion[]     @relation("PlanVersionParent")
  restoredFromVersion   PlanVersion?      @relation("PlanVersionRestore", fields: [restoredFromVersionId], references: [id], onDelete: SetNull)
  restoredVersions      PlanVersion[]     @relation("PlanVersionRestore")

  @@unique([planId, revision])
  @@index([planId, revision(sort: Desc)])
  @@index([planId, createdAt(sort: Desc)])
  @@index([planId, source])
}

model PlanShareLink {
  id          String          @id @default(uuid()) @db.Uuid
  planId      String          @unique @map("plan_id") @db.Uuid
  accessLevel PlanAccessLevel @default(viewer) @map("access_level")
  enabled     Boolean         @default(true)
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  plan        Plan            @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([enabled, accessLevel])
}

model PlanAccess {
  id              String           @id @default(uuid()) @db.Uuid
  planId          String           @map("plan_id") @db.Uuid
  userId          String           @map("user_id") @db.Uuid
  accessLevel     PlanAccessLevel  @map("access_level")
  status          PlanAccessStatus @default(pending)
  grantedByUserId String           @map("granted_by_user_id") @db.Uuid
  createdAt       DateTime         @default(now()) @map("created_at")
  acceptedAt      DateTime?        @map("accepted_at")
  revokedAt       DateTime?        @map("revoked_at")
  plan            Plan             @relation(fields: [planId], references: [id], onDelete: Cascade)
  user            User             @relation("PlanAccessUser", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy       User             @relation("PlanAccessGrantor", fields: [grantedByUserId], references: [id], onDelete: Restrict)

  @@unique([planId, userId])
  @@index([userId, status])
}

model ApplicationSetting {
  key       String   @id @db.VarChar(100)
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")
}

model EmailConfiguration {
  id                  String   @id @default(uuid()) @db.Uuid
  environment         String   @unique @db.VarChar(30)
  host                String?  @db.VarChar(255)
  port                Int?
  secure              Boolean  @default(true)
  username            String?  @db.VarChar(255)
  encryptedPassword   String?  @map("encrypted_password") @db.Text
  senderEmail         String?  @map("sender_email") @db.VarChar(320)
  senderName          String?  @map("sender_name") @db.VarChar(120)
  replyTo             String?  @map("reply_to") @db.VarChar(320)
  enabled             Boolean  @default(false)
  timeoutMs           Int      @default(10000) @map("timeout_ms")
  frontendUrl         String?  @map("frontend_url") @db.VarChar(500)
  resetExpiresMinutes Int      @default(30) @map("reset_expires_minutes")
  updatedAt           DateTime @updatedAt @map("updated_at")
}

model EmailTemplate {
  key       String   @id @db.VarChar(100)
  version   Int      @default(1)
  subject   String   @db.VarChar(240)
  htmlBody  String   @map("html_body") @db.Text
  textBody  String   @map("text_body") @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")
}

model EmailDeliveryLog {
  id              String   @id @default(uuid()) @db.Uuid
  templateKey     String?  @map("template_key") @db.VarChar(100)
  templateVersion Int?     @map("template_version")
  recipientHash   String   @map("recipient_hash") @db.Char(64)
  provider        String   @db.VarChar(50)
  status          String   @db.VarChar(30)
  errorCode       String?  @map("error_code") @db.VarChar(80)
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([status, createdAt])
}
