NODE_ENV=development
PORT=4100
DATABASE_URL=postgresql://northstar:northstar@127.0.0.1:5432/northstar_planner?schema=public
APP_ORIGIN=http://localhost:5173
SESSION_TTL_HOURS=168
COOKIE_SECURE=false
TRUST_PROXY=false
REGISTRATION_ENABLED=true
EMAIL_VERIFICATION_REQUIRED=false
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_DISPLAY_NAME=NorthStar Admin
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4100/api/auth/google/callback
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5
PASSWORD_RESET_TTL_MINUTES=30
EMAIL_VERIFICATION_TTL_HOURS=24
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=NorthStar Planner
# Generate with: openssl rand -base64 32
EMAIL_ENCRYPTION_KEY=
# Required in production. Generate independently with: openssl rand -hex 32
AI_GUEST_SESSION_SIGNING_KEY=
AI_PROVIDER=mock
# Backend only. Never prefix this variable with VITE_.
OPENAI_API_KEY=
OPENAI_PROPOSAL_MODEL=gpt-5.6-sol
OPENAI_CONVERSION_MODEL=gpt-5.6-sol
OPENAI_TIMEOUT_MS=20000
